APP_NAME="Meu Marqueteiro"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt_BR

# ─────────────────────────────────────────────
# DATABASE (PostgreSQL + pgvector)
# ─────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=meu_marqueteiro
DB_USERNAME=postgres
DB_PASSWORD=secret

# ─────────────────────────────────────────────
# CACHE / QUEUE / SESSION
# ─────────────────────────────────────────────
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─────────────────────────────────────────────
# AI PROVIDERS (multi-provider)
# ─────────────────────────────────────────────
AI_DEFAULT_PROVIDER=anthropic        # openai | anthropic | gemini

# OpenAI
OPENAI_API_KEY=sua-credencial
OPENAI_ORGANIZATION=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic (Claude)
ANTHROPIC_API_KEY=sua-credencial
ANTHROPIC_MODEL=claude-opus-4-6

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# ─────────────────────────────────────────────
# RAG / VECTOR STORE (pgvector)
# ─────────────────────────────────────────────
VECTOR_DIMENSIONS=1536             # 1536 for OpenAI, 768 for others
VECTOR_SIMILARITY_THRESHOLD=0.75
VECTOR_MAX_RESULTS=10

# ─────────────────────────────────────────────
# STORAGE (S3-compatible)
# ─────────────────────────────────────────────
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=sa-east-1
AWS_BUCKET=meu-marqueteiro
AWS_ENDPOINT=                      # para MinIO ou Cloudflare R2

# ─────────────────────────────────────────────
# MAIL
# ─────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@meumarqueteiro.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────────
# INTEGRAÇÕES — APIS PÚBLICAS MUNICIPAIS
# ─────────────────────────────────────────────
SICONFI_BASE_URL=https://apidatalake.tesouro.gov.br/ords/siconfi
FNDE_BASE_URL=https://www.fnde.gov.br/fndeapi
IBGE_BASE_URL=https://servicodados.ibge.gov.br/api/v3
DATASUS_BASE_URL=https://datasus.saude.gov.br
PORTAL_TRANSPARENCIA_API_KEY=
PORTAL_TRANSPARENCIA_BASE_URL=https://api.portaldatransparencia.gov.br/api-de-dados

# ─────────────────────────────────────────────
# BROADCASTING (Reverb)
# ─────────────────────────────────────────────
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=meu-marqueteiro
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# ─────────────────────────────────────────────
# NOTIFICAÇÕES
# ─────────────────────────────────────────────
WHATSAPP_PROVIDER=twilio          # twilio | z-api | evolution-api
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# ─────────────────────────────────────────────
# SENTRY (monitoramento de erros)
# ─────────────────────────────────────────────
SENTRY_LARAVEL_DSN=

# ─────────────────────────────────────────────
# BRIEFING MATINAL (cron)
# ─────────────────────────────────────────────
MORNING_BRIEFING_HOUR=6           # hora de geração (BRT)
MORNING_BRIEFING_MINUTE=30
